#    fast to build. Uncomment to crop to a central window or downsample.
# r <- terra::crop(r, terra::ext(500, 1500, 500, 1500))   # central 1000 x 1000
# r <- terra::aggregate(r, fact = 2, fun = "max")          # halve resolution
# 5. Match the existing example data, which are stored as raster::RasterBrick
#    and reconstructed in the vignettes with terra::rast(...).
flatbed_scan_example <- 3#raster::brick(r)
# 6. Save into data/ with xz compression (matches DESCRIPTION LazyDataCompression).
usethis::use_data(flatbed_scan_example, compress = "xz", overwrite = TRUE)
# After this, `devtools::document()` regenerates man/flatbed_scan_example.Rd
# from the roxygen block in R/data.R, and the flatbed vignette will load it via
#   data(flatbed_scan_example); seg <- terra::rast(flatbed_scan_example)
library(terra)
library(raster)
# 1. Point this at your local file (edit the path as needed)
src <- "C:/Users/jocu0013/Desktop/Rjanka diameter testing/test.tiff"
# 2. Read it. terra reads the geotiff tags fine; the "Unknown field" warnings
#    from tiff::readTIFF are harmless metadata notices.
r <- terra::rast(src)
r <- r[[1:3]]
# 3. Sanity checks: a segmentation should be 3-band and effectively 0/1.
print(r)                       # expect ~2000 x 2000 x 3, min 0 / max 1
stopifnot(terra::nlyr(r) == 3)
# 5. Match the existing example data, which are stored as raster::RasterBrick
#    and reconstructed in the vignettes with terra::rast(...).
