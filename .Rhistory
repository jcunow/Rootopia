result
}
# ---------------------------------------------------------------------------
# MAT — kept for root_diameter() only
# ---------------------------------------------------------------------------
#' Medial Axis Transform — for diameter measurement only (internal)
#'
#' Uses local maxima of the Euclidean distance transform.  **Do not use for
#' skeletonization** — MAT breaks connectivity at thin-to-thick junctions
#' (skeleton/root ratio ~ 0.01 on real images).  Use [skeletonize_image()]
#' instead.  [root_diameter()] calls this internally for accurate centreline
#' position.
#'
#' @param img Binary raster, matrix, or any format for `load_flexible_image()`.
#' @param verbose Logical. Default `FALSE`.
#' @param select.layer Integer or `NULL`.
#' @return Binary integer matrix (0/1).
#' @keywords internal
medial_axis_transform <- function(img, verbose = FALSE, select.layer = NULL) {
img_cimg <- tryCatch(
load_flexible_image(img, output_format = "cimg",
normalize = TRUE, binarize = TRUE,
select.layer = select.layer),
error = function(e) stop("Failed to load image for MAT: ", e$message)
)
if (verbose)
cat(sprintf("MAT: %d x %d, %d foreground pixels\n",
dim(img_cimg)[1], dim(img_cimg)[2], sum(img_cimg > 0)))
edt <- tryCatch(
imager::distance_transform(img_cimg, value = 0L, metric = 2L),
error = function(e) stop("EDT failed: ", e$message)
)
if (all(edt == 0)) warning("MAT: distance transform all zero")
if (verbose) cat("MAT: distance transform complete\n")
edt_mat <- t(as.array(edt)[, , 1, 1])
img_mat <- t(as.array(img_cimg)[, , 1, 1])
R <- nrow(edt_mat); C <- ncol(edt_mat)
skeleton <- matrix(0L, R, C)
for (i in seq(2L, R-1L))
for (j in seq(2L, C-1L))
if (img_mat[i,j] > 0 && edt_mat[i,j] > 0 &&
edt_mat[i,j] >= max(edt_mat[(i-1L):(i+1L), (j-1L):(j+1L)]))
skeleton[i,j] <- 1L
if (all(skeleton == 0L)) warning("MAT: no skeleton points detected")
if (verbose) cat(sprintf("MAT: %d skeleton pixels\n", sum(skeleton)))
skeleton
}
# ---------------------------------------------------------------------------
# Detect skeleton endpoints and branching points
# ---------------------------------------------------------------------------
#' Detect Skeleton Points: Branching Points and Endpoints
#'
#' @param img Binary `SpatRaster`, matrix, or any format for
#'   `load_flexible_image()`.
#' @param select.layer Integer. Layer for multi-layer inputs. Default `2`.
#' @return Named list: `endpoints` and `branching_points` as `SpatRaster`.
#' @seealso [skeletonize_image()]
#' @export
#' @examples
#' data(skl_Oulanka2023_Session01_T067)
#' img <- terra::rast(skl_Oulanka2023_Session01_T067)[[2]]
#' pts <- detect_skeleton_points(img, select.layer = NULL)
#' terra::plot(pts$endpoints)
detect_skeleton_points <- function(img, select.layer = 2) {
img_mat <- tryCatch({
r <- load_flexible_image(img, select.layer = select.layer,
output_format = "spatrast",
normalize = TRUE, binarize = TRUE)
matrix(as.numeric(terra::values(r)), nrow = nrow(r), ncol = ncol(r),
byrow = TRUE)
}, error = function(e)
stop("Failed to load image in detect_skeleton_points: ", e$message))
if (!all(img_mat %in% c(0, 1)))
stop("Input must be binary for skeleton point detection")
kernel <- matrix(1L, 3L, 3L); kernel[2L, 2L] <- 0L
padded <- matrix(0L, nrow(img_mat)+2L, ncol(img_mat)+2L)
padded[2:(nrow(img_mat)+1L), 2:(ncol(img_mat)+1L)] <- img_mat
n_count <- matrix(0L, nrow(img_mat), ncol(img_mat))
for (i in seq_len(nrow(img_mat)))
for (j in seq_len(ncol(img_mat)))
n_count[i,j] <- sum(padded[i:(i+2L), j:(j+2L)] * kernel)
endpoints        <- (img_mat == 1L) & (n_count == 1L)
branching_points <- (img_mat == 1L) & (n_count >  2L)
if (!any(endpoints) && !any(branching_points))
warning("No endpoints or branching points detected")
list(endpoints        = terra::rast(endpoints        * 1L),
branching_points = terra::rast(branching_points * 1L))
}
# ---------------------------------------------------------------------------
# Public wrapper
# ---------------------------------------------------------------------------
#' Skeletonise a binary root image
#'
#' @description
#' Reduces a binary segmented root image to a one-pixel-wide, topologically
#' correct centreline using a **hybrid thinning** algorithm.
#'
#' @section Algorithm:
#' **Phase 1 — parallel thick pass** (`terra::focal`, fast C++):
#' Foreground pixels with Euclidean distance-transform value > 1.5 px are
#' safely inside thick blobs — they can be removed in parallel using the
#' Zhang-Suen simple-point condition (A == 1) without any topology risk.
#' This collapses all thick structure to ≈ 1–2 px width in a small number
#' of iterations.
#'
#' **Phase 2 — sequential thin pass** (R loop, small pixel set):
#' The thin residual after Phase 1 is processed strictly one pixel at a
#' time: a pixel is removed if and only if it is a **simple point** (its
#' removal cannot disconnect or merge any connected component).  Because
#' Phase 1 has already removed > 95 % of pixels, this sequential phase
#' is fast in practice.
#'
#' The result is **1-pixel wide**, **connected** (topology-preserving by
#' construction), and **homotopy-correct** (holes are preserved).
#'
#' @section Why not plain Zhang-Suen?
#' Pure parallel ZS deletes adjacent critical pixels simultaneously,
#' breaking connectivity at: thin connectors between blobs, curved root
#' tips, junction points of 3+ branches, and ring-shaped structures.
#' These failures occur on all realistic cleaned root images regardless
#' of the variant (ZS, Guo-Hall, etc.).
#'
#' @section Clean before skeletonising:
#' Small holes produce spurious branching; isolated specks produce phantom
#' skeleton segments.  Always run `clean_image()` first:
#' ```r
#' cleaned <- clean_image(img, max_hole_size = 50, max_artifact_size = 10)
#' skel    <- skeletonize_image(cleaned)
#' ```
#'
#' @param img Binary `SpatRaster`, matrix, or any format accepted by
#'   `load_flexible_image()`.
#' @param methods Character.  Only `"ZhangSuen"` is accepted (default).
#'   Passing `"MAT"` raises an informative error.
#' @param thick_threshold Numeric.  EDT threshold (px) separating the
#'   parallel-safe thick pixels from the topology-critical thin pixels.
#'   Default `1.5`.  Rarely needs changing.
#' @param verbose Logical.  Print phase statistics.  Default `TRUE`.
#' @param select.layer Integer or `NULL`.  Layer for multi-layer inputs.
#' @return Binary `SpatRaster` (skeleton = 1, background = 0).
#' @export
#' @examples
#' data(seg_Oulanka2023_Session01_T067)
#' img <- terra::rast(seg_Oulanka2023_Session01_T067)
#' cleaned <- clean_image(img, max_hole_size = 50, max_artifact_size = 10,
#'                        select.layer = 2)
#' skel <- skeletonize_image(cleaned, verbose = TRUE)
#' terra::plot(skel)
skeletonize_image <- function(img,
methods          = "ZhangSuen",
thick_threshold  = 1.5,
verbose          = TRUE,
select.layer     = NULL) {
if (any(c("MAT", "SteepestAscend") %in% methods))
stop(paste0(
'skeletonize_image() does not support "MAT" or "SteepestAscend".\n',
"MAT breaks connectivity at thin-to-thick junctions (ratio ~0.01 on real data).\n",
'Use methods = "ZhangSuen" (the default) for a topology-preserving skeleton.'
), call. = FALSE)
if (any("GuoHall" %in% methods)) {
warning('"GuoHall" removed — using "ZhangSuen".', call. = FALSE)
methods <- "ZhangSuen"
}
if (!"ZhangSuen" %in% methods)
stop(sprintf('Unknown method "%s". Only "ZhangSuen" is supported.',
methods[1L]), call. = FALSE)
if (verbose) cat("Skeletonizing (hybrid topology-preserving thinning)...\n")
img_rast <- tryCatch(
load_flexible_image(img, output_format = "spatrast",
normalize = TRUE, binarize = TRUE,
select.layer = select.layer),
error = function(e) stop("Failed to load image: ", e$message)
)
if (terra::nlyr(img_rast) > 1L) {
warning("Multi-layer input — using layer 1 after binarization")
img_rast <- img_rast[[1L]]
}
n_root <- sum(terra::values(img_rast) == 1, na.rm = TRUE)
if (n_root == 0L) stop("No foreground pixels after binarization")
result <- hybrid_thin(img_rast,
thick_threshold = thick_threshold,
max_thick_iter  = 100L,
verbose         = verbose)
n_skel <- sum(terra::values(result) == 1, na.rm = TRUE)
if (verbose)
cat(sprintf("Done. Root px: %d  Skeleton px: %d  Ratio: %.3f\n",
n_root, n_skel, n_skel / max(n_root, 1L)))
result
}
skel <- skeletonize_image(cleaned, methods = "ZhangSuen", verbose = TRUE)
skel_px <- sum(terra::values(skel) == 1, na.rm = TRUE)
cat("Skeleton pixels:", skel_px, "\n")
# Ratio: skeleton px / root px.  For thin roots this should be ~0.3-0.7.
# Very low ratio (<0.1) suggests the skeleton is too sparse (chopped up).
ratio <- skel_px / root_px_after
cat(sprintf("Skeleton/root pixel ratio: %.3f\n", ratio))
if (ratio < 0.05) {
cat("WARNING: ratio is very low — skeleton may be fragmented or mostly missing.\n")
} else if (ratio > 0.85) {
cat("WARNING: ratio is very high — skeleton may be over-broad (not thinned properly).\n")
} else {
cat("Ratio looks plausible.\n")
}
cat("\n")
skel_crop <- terra::crop(skel,
terra::ext(0, CROP_C, nrow(skel) - CROP_R, nrow(skel)))
par(mfrow = c(1, 2))
terra::plot(cleaned_crop, col = c("white", "black"),
main = "Cleaned segmentation", legend = FALSE)
terra::plot(skel_crop, col = c("white", "firebrick"),
main = "MAT skeleton (red)", legend = FALSE)
par(mfrow = c(1, 1))
skel <- skeletonize_image(cleaned, methods = "MAT", verbose = TRUE)
