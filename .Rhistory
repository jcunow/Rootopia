# data-raw/flatbed_scan_example.R
# ---------------------------------------------------------------------------
# Build the bundled `flatbed_scan_example` dataset from a local segmented
# flatbed TIFF. Run this once from the package root; it writes
# data/flatbed_scan_example.rda. Re-run only when the source image changes.
#
# Requirements: terra, raster, usethis (all already available in the project).
# ---------------------------------------------------------------------------
library(terra)
library(raster)
# 1. Point this at your local file (edit the path as needed)
src <- "C:/Users/jocu0013/Desktop/Rjanka diameter testing/test.tiff"
# 2. Read it. terra reads the geotiff tags fine; the "Unknown field" warnings
#    from tiff::readTIFF are harmless metadata notices.
r <- terra::rast(src)
r <- r[[1:3]]
# 3. Sanity checks: a segmentation should be 3-band and effectively 0/1.
print(r)                       # expect ~2000 x 2000 x 3, min 0 / max 1
stopifnot(terra::nlyr(r) == 3)
# 4. (Optional) Shrink the example to keep package data small and the vignette
#    fast to build. Uncomment to crop to a central window or downsample.
# r <- terra::crop(r, terra::ext(500, 1500, 500, 1500))   # central 1000 x 1000
# r <- terra::aggregate(r, fact = 2, fun = "max")          # halve resolution
# 5. Match the existing example data, which are stored as raster::RasterBrick
#    and reconstructed in the vignettes with terra::rast(...).
flatbed_scan_example <- r#raster::brick(r)
# 6. Save into data/ with xz compression (matches DESCRIPTION LazyDataCompression).
usethis::use_data(flatbed_scan_example, compress = "xz", overwrite = TRUE)
# After this, `devtools::document()` regenerates man/flatbed_scan_example.Rd
# from the roxygen block in R/data.R, and the flatbed vignette will load it via
#   data(flatbed_scan_example); seg <- terra::rast(flatbed_scan_example)
library(terra)
# 0. Run this from the PACKAGE ROOT (the folder containing DESCRIPTION), e.g.
#       setwd("path/to/RootScanR"); source("data-raw/flatbed_scan_example.R")
#    Also delete any earlier/broken version first, otherwise load_all()/document()
#    will choke on a stale object:
if (file.exists("data/flatbed_scan_example.rda")) {
unlink("data/flatbed_scan_example.rda")
}
# 1. Point this at your local file (edit the path as needed)
src <- "C:/Users/jocu0013/Desktop/Rjanka diameter testing/test.tiff"
# 2. Read it. terra reads the geotiff tags fine; the "Unknown field" warnings
#    from tiff::readTIFF are harmless metadata notices.
r <- terra::rast(src)
# 3. Sanity checks: a segmentation should be 3-band and effectively 0/1.
print(r)                       # expect ~2000 x 2000 x 3, min 0 / max 1
stopifnot(terra::nlyr(r) == 3)
# 5. Store as a PLAIN NUMERIC ARRAY [rows, cols, layers] -- this is exactly how
#    the other bundled datasets (seg_/skl_/rgb_/TurnoverDPC_data) are stored.
#    A terra SpatRaster (or terra::wrap/raster::brick) must NOT be saved: terra
#    objects hold external pointers that are dead after serialization, which is
#    what triggers the "CppMethod__invoke_notvoid / NULL value passed as symbol
#    address" error during load_all()/document(). An array round-trips cleanly
#    via terra::rast(array) and compresses very well for a binary mask.
flatbed_scan_example <- terra::as.array(r)
storage.mode(flatbed_scan_example) <- "double"
# 6. Save into data/ with xz compression (matches DESCRIPTION LazyDataCompression).
usethis::use_data(flatbed_scan_example, compress = "xz", overwrite = TRUE)
setwd("path/to/RootScanR")     # important — fixes your "cannot open file" error
devtools::document()           # now succeeds and regenerates the Rd itself
devtools::load_all()
flatbed_scan_example
plot(flatbed_scan_example)
terra::plot(flatbed_scan_example)
